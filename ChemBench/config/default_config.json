{
  "seed": 42,
  "cv_splits": 5,
  "save": {
    "prefer_pickle": true
  },
  "algorithms": {
    "ridge": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "alpha": 1.0
      }
    },
    "elastic_net": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "alpha": 0.1,
        "l1_ratio": 0.5,
        "max_iter": 5000
      }
    },
    "random_forest": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "n_estimators": 600,
        "max_depth": 20,
        "min_samples_split": 2,
        "min_samples_leaf": 1,
        "max_features": "sqrt"
      }
    },
    "svr": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "C": 10.0,
        "epsilon": 0.1,
        "kernel": "rbf",
        "gamma": "scale"
      }
    },
    "knn": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "n_neighbors": 10,
        "weights": "distance",
        "p": 2
      }
    },
    "xgboost": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "n_estimators": 500,
        "max_depth": 8,
        "learning_rate": 0.05,
        "subsample": 0.8,
        "colsample_bytree": 0.8
      }
    },
    "lightgbm": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "n_estimators": 500,
        "learning_rate": 0.05,
        "num_leaves": 63,
        "subsample": 0.8,
        "colsample_bytree": 0.8
      }
    },
    "gpr": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "alpha": 1e-06,
        "normalize_y": true
      }
    },
    "mlp": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "hidden_layer_sizes": [
          128,
          64
        ],
        "activation": "relu",
        "solver": "adam",
        "alpha": 0.0001,
        "learning_rate_init": 0.001,
        "batch_size": "auto",
        "max_iter": 300,
        "early_stopping": true,
        "n_iter_no_change": 20
      }
    }
  }
}
