{
  "seed": 42,
  "cv_splits": 5,
  "save": {
    "prefer_pickle": true
  },
  "algorithms": {
    "ridge": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "alpha": 1.0
      }
    },
    "elastic_net": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "alpha": 0.05,
        "l1_ratio": 0.4,
        "max_iter": 8000
      }
    },
    "random_forest": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "n_estimators": 600,
        "max_depth": 20,
        "min_samples_split": 2,
        "min_samples_leaf": 1,
        "max_features": "sqrt"
      }
    },
    "svr": {
      "enabled": false,
      "use_gpu": false,
      "params": {
        "C": 10.0,
        "epsilon": 0.1,
        "kernel": "rbf",
        "gamma": "scale"
      }
    },
    "knn": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "n_neighbors": 25,
        "weights": "distance",
        "p": 2
      }
    },
    "xgboost": {
      "enabled": true,
      "use_gpu": true,
      "params": {
        "n_estimators": 700,
        "max_depth": 7,
        "learning_rate": 0.05,
        "subsample": 0.85,
        "colsample_bytree": 0.85,
        "reg_alpha": 0.0,
        "reg_lambda": 1.0
      }
    },
    "lightgbm": {
      "enabled": true,
      "use_gpu": true,
      "params": {
        "n_estimators": 700,
        "learning_rate": 0.05,
        "num_leaves": 127,
        "subsample": 0.85,
        "colsample_bytree": 0.85,
        "min_child_samples": 30
      }
    },
    "gpr": {
      "enabled": false,
      "use_gpu": false,
      "params": {
        "alpha": 1e-06,
        "normalize_y": true
      }
    },
    "mlp": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "hidden_layer_sizes": [
          256,
          128
        ],
        "activation": "relu",
        "solver": "adam",
        "alpha": 0.0001,
        "learning_rate_init": 0.001,
        "batch_size": 256,
        "max_iter": 300,
        "early_stopping": true,
        "n_iter_no_change": 20
      }
    }
  }
}
