{
  "seed": 42,
  "cv_splits": 5,
  "feature_options": {
    "atom_pair_nbits": 2048,
    "mordred_use_3d": false
  },
  "save": {
    "prefer_pickle": true
  },
  "algorithms": {
    "ridge": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "alpha": 1.0
      }
    },
    "elastic_net": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "alpha": 0.05,
        "l1_ratio": 0.5,
        "max_iter": 10000
      }
    },
    "svr": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "C": 10.0,
        "epsilon": 0.05,
        "kernel": "rbf",
        "gamma": "scale"
      }
    },
    "knn": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "n_neighbors": 15,
        "weights": "distance",
        "p": 2
      }
    },
    "xgboost": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "n_estimators": 800,
        "max_depth": 8,
        "learning_rate": 0.03,
        "subsample": 0.8,
        "colsample_bytree": 0.8,
        "reg_alpha": 0.0,
        "reg_lambda": 1.0
      }
    },
    "lightgbm": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "n_estimators": 800,
        "learning_rate": 0.03,
        "num_leaves": 127,
        "subsample": 0.8,
        "colsample_bytree": 0.8
      }
    },
    "gpr": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "alpha": 1e-06,
        "normalize_y": true
      }
    },
    "mlp": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "hidden_layer_sizes": [
          256,
          128
        ],
        "activation": "relu",
        "solver": "adam",
        "alpha": 1e-04,
        "learning_rate_init": 0.001,
        "batch_size": 128,
        "max_iter": 400,
        "early_stopping": true,
        "n_iter_no_change": 20
      }
    }
  }
}

