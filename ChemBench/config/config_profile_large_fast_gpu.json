{
  "seed": 42,
  "cv_splits": 5,
  "save": {
    "prefer_pickle": true
  },
  "algorithms": {
    "ridge": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "alpha": 1.0
      }
    },
    "elastic_net": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "alpha": 0.01,
        "l1_ratio": 0.3,
        "max_iter": 6000
      }
    },
    "svr": {
      "enabled": false,
      "use_gpu": false,
      "params": {
        "C": 10.0,
        "epsilon": 0.1,
        "kernel": "rbf",
        "gamma": "scale"
      }
    },
    "knn": {
      "enabled": false,
      "use_gpu": false,
      "params": {
        "n_neighbors": 30,
        "weights": "distance",
        "p": 2
      }
    },
    "xgboost": {
      "enabled": true,
      "use_gpu": true,
      "params": {
        "n_estimators": 1000,
        "max_depth": 8,
        "learning_rate": 0.05,
        "subsample": 0.8,
        "colsample_bytree": 0.8,
        "min_child_weight": 3,
        "reg_alpha": 0.0,
        "reg_lambda": 1.0
      }
    },
    "lightgbm": {
      "enabled": true,
      "use_gpu": true,
      "params": {
        "n_estimators": 1200,
        "learning_rate": 0.03,
        "num_leaves": 255,
        "subsample": 0.8,
        "colsample_bytree": 0.8,
        "min_child_samples": 50
      }
    },
    "gpr": {
      "enabled": false,
      "use_gpu": false,
      "params": {
        "alpha": 1E-06,
        "normalize_y": true
      }
    },
    "mlp": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "hidden_layer_sizes": [
          256,
          128
        ],
        "activation": "relu",
        "solver": "adam",
        "alpha": 0.0001,
        "learning_rate_init": 0.001,
        "batch_size": 512,
        "max_iter": 200,
        "early_stopping": true,
        "n_iter_no_change": 15
      }
    }
  }
}
