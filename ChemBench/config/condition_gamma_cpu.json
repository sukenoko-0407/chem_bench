{
  "seed": 42,
  "cv_splits": 5,
  "save": {
    "prefer_pickle": true
  },
  "algorithms": {
    "ridge": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "alpha": 2.0
      }
    },
    "elastic_net": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "max_iter": 10000,
        "l1_ratio": 0.6,
        "alpha": 0.03
      }
    },
    "svr": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "epsilon": 0.01,
        "C": 20.0,
        "gamma": "scale",
        "kernel": "rbf"
      }
    },
    "knn": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "n_neighbors": 21,
        "weights": "distance",
        "p": 2
      }
    },
    "xgboost": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "max_depth": 8,
        "n_estimators": 1400,
        "min_child_weight": 2,
        "learning_rate": 0.02,
        "subsample": 1.0,
        "reg_lambda": 2.0,
        "reg_alpha": 0.0001,
        "colsample_bytree": 1.0
      }
    },
    "lightgbm": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "n_estimators": 1600,
        "learning_rate": 0.025,
        "colsample_bytree": 1.0,
        "reg_alpha": 0.0001,
        "subsample": 1.0,
        "num_leaves": 255,
        "reg_lambda": 2.0,
        "max_depth": -1,
        "min_child_samples": 30
      }
    },
    "gpr": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "alpha": 1E-06,
        "normalize_y": true
      }
    },
    "mlp": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "max_iter": 500,
        "hidden_layer_sizes": [
          512,
          256
        ],
        "learning_rate_init": 0.0008,
        "alpha": 5E-05,
        "early_stopping": true,
        "solver": "adam",
        "activation": "relu",
        "batch_size": 128,
        "n_iter_no_change": 25
      }
    }
  }
}
