{
  "seed": 42,
  "cv_splits": 5,
  "feature_options": {
    "atom_pair_nbits": 2048,
    "mordred_use_3d": false
  },
  "save": {
    "prefer_pickle": true
  },
  "algorithms": {
    "ridge": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "alpha": 1.0
      }
    },
    "elastic_net": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "max_iter": 12000,
        "l1_ratio": 0.3,
        "alpha": 0.02
      }
    },
    "svr": {
      "enabled": false,
      "use_gpu": false,
      "params": {
        "epsilon": 0.03,
        "C": 30.0,
        "gamma": "scale",
        "kernel": "rbf"
      }
    },
    "knn": {
      "enabled": false,
      "use_gpu": false,
      "params": {
        "n_neighbors": 11,
        "weights": "distance",
        "p": 2
      }
    },
    "xgboost": {
      "enabled": true,
      "use_gpu": true,
      "params": {
        "max_depth": 10,
        "n_estimators": 2600,
        "min_child_weight": 2,
        "learning_rate": 0.02,
        "subsample": 0.9,
        "reg_lambda": 1.0,
        "reg_alpha": 0.0,
        "colsample_bytree": 0.9
      }
    },
    "lightgbm": {
      "enabled": true,
      "use_gpu": true,
      "params": {
        "n_estimators": 3000,
        "learning_rate": 0.015,
        "colsample_bytree": 0.9,
        "reg_alpha": 0.0,
        "subsample": 0.9,
        "num_leaves": 255,
        "reg_lambda": 1.0,
        "max_depth": -1,
        "min_child_samples": 50
      }
    },
    "gpr": {
      "enabled": false,
      "use_gpu": false,
      "params": {
        "alpha": 1E-08,
        "normalize_y": true
      }
    },
    "mlp": {
      "enabled": true,
      "use_gpu": false,
      "params": {
        "max_iter": 500,
        "hidden_layer_sizes": [
          512,
          256
        ],
        "learning_rate_init": 0.0007,
        "alpha": 1E-05,
        "early_stopping": true,
        "solver": "adam",
        "activation": "relu",
        "batch_size": 512,
        "n_iter_no_change": 30
      }
    }
  }
}
